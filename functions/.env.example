# Meta WhatsApp Business Cloud API
WHATSAPP_TOKEN=EAA...              # Permanent oder Test-Token aus Meta for Developers
WHATSAPP_PHONE_ID=123456789012345  # Phone Number ID aus Meta (nicht die Nummer selbst!)
WHATSAPP_VERIFY_TOKEN=einGeheimerStringDenIchSelbstWaehle
# Komma-separierte Empfänger im internationalen Format OHNE +
WHATSAPP_GROUP_RECIPIENTS=41791112233,41794445566

# ===================================================================
# Smart Plugs (für Pumpe, Bewässerung, etc.)
# ===================================================================
# Provider: "tuya" (Default, für Smart Life / Maxcio / Smart-Life-kompatible Plugs)
#           "meross" (für Refoss/Meross-Plugs wie MSS210P)
PLUG_PROVIDER=tuya

# --- Tuya (Smart Life / Maxcio) ---
# Anleitung:
#  1) iot.tuya.com → Sign Up als Developer (kostenlos)
#  2) Cloud → Development → Create Cloud Project (Region: Central Europe)
#  3) Im Projekt: "Service API" → "IoT Core" und "Authorization Token Management" aktivieren
#  4) Tab "Devices" → "Link Tuya App Account" → QR-Code mit der Smart-Life-App scannen
#  5) Werte unten eintragen:
TUYA_ACCESS_ID=
TUYA_ACCESS_SECRET=
TUYA_UID=
TUYA_REGION=eu            # eu | us | cn | in

# --- Meross / Refoss (nur falls PLUG_PROVIDER=meross) ---
# MEROSS_EMAIL=
# MEROSS_PASSWORD=
