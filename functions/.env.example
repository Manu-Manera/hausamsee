# Meta WhatsApp Business Cloud API
WHATSAPP_TOKEN=EAA...              # Permanent oder Test-Token aus Meta for Developers
WHATSAPP_PHONE_ID=123456789012345  # Default: Phone Number ID (Fallback + broadcast). Eingehende Antworten nutzen value.metadata.phone_number_id, damit Test- + Hauptnummer parallel gehen.
WHATSAPP_VERIFY_TOKEN=einGeheimerStringDenIchSelbstWaehle
# Komma-separierte Empfänger im internationalen Format OHNE +
WHATSAPP_GROUP_RECIPIENTS=41791112233,41794445566

# Garten-Regen-Alert (Open-Meteo Pfäffikon) → ca. 30 min vor Niederschlag, WhatsApp „Gartenpolster rein“
# Leer lassen = aus. Zum Einschalten: 1, true, on oder yes
# GARTEN_RAIN_ALERT=1
# Optional: nur für Regen-Alert (sonst WHATSAPP_GROUP_RECIPIENTS)
# WHATSAPP_RAIN_ALERT_RECIPIENTS=4179...

# ===================================================================
# Smart Plugs (für Pumpe, Bewässerung, etc.)
# ===================================================================
# Provider: "tuya" (Default, für Smart Life / Maxcio / Smart-Life-kompatible Plugs)
#           "meross" (für Refoss/Meross-Plugs wie MSS210P)
PLUG_PROVIDER=tuya

# --- Tuya (Smart Life / Maxcio) ---
# Anleitung:
#  1) iot.tuya.com → Sign Up als Developer (kostenlos)
#  2) Cloud → Development → Create Cloud Project (Region: Central Europe)
#  3) Im Projekt: "Service API" → "IoT Core" und "Authorization Token Management" aktivieren
#  4) Tab "Devices" → "Link Tuya App Account" → QR-Code mit der Smart-Life-App scannen
#  5) Werte unten eintragen:
TUYA_ACCESS_ID=
TUYA_ACCESS_SECRET=
TUYA_UID=
TUYA_REGION=eu            # eu | us | cn | in

# --- Meross / Refoss (nur falls PLUG_PROVIDER=meross) ---
# MEROSS_EMAIL=
# MEROSS_PASSWORD=

# ===================================================================
# Natürliche Sprache (OpenAI) – optional, Gustav versteht dann Umgangssprache
# ===================================================================
# openai.com API-Key; ohne Key bleibt alles regelbasiert (wie bisher)
OPENAI_API_KEY=
# z. B. gpt-4.1 (Default im Code), gpt-5.2, … – muss in deinem OpenAI-Projekt freigeschaltet sein
# OPENAI_MODEL=gpt-4.1
# GUSTAV_LLM=off  # Bot nur mit festen Befehlen, kein LLM
# GUSTAV_LLM_RULES_FIRST=1  # Statt KI zuerst: zuerst feste Syntax, dann LLM (weniger KI, schneller)
