rules_version = '2';

// Firestore Regeln für beide Apps:
// - wishes: Geburtstags-Wunschliste (giftforchris.ch)
// - events, besuche, putzplan, termine, anwesenheit, gaestebuch: Haus am See
service cloud.firestore {
  match /databases/{database}/documents {
    match /wishes/{document=**} {
      allow read, write: if true;
    }
    match /events/{document=**} {
      allow read, write: if true;
    }
    match /besuche/{document=**} {
      allow read, write: if true;
    }
    match /putzplan/{document=**} {
      allow read, write: if true;
    }
    match /termine/{document=**} {
      allow read, write: if true;
    }
    match /anwesenheit/{document=**} {
      allow read, write: if true;
    }
    match /gaestebuch/{document=**} {
      allow read, write: if true;
    }
    match /galerie/{document=**} {
      allow read, write: if true;
    }
  }
}
