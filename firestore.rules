rules_version = '2';

// Firestore Regeln für Haus am See
// Projekt: haus-am-see-d91ef (europe-west / Zürich)
service cloud.firestore {
  match /databases/{database}/documents {
    match /events/{document=**} {
      allow read, write: if true;
    }
    match /putzplan/{document=**} {
      allow read, write: if true;
    }
    match /termine/{document=**} {
      allow read, write: if true;
    }
    match /anwesenheit/{document=**} {
      allow read, write: if true;
    }
    match /gaestebuch/{document=**} {
      allow read, write: if true;
    }
    match /galerie/{document=**} {
      allow read, write: if true;
    }
    match /musik/{document=**} {
      allow read, write: if true;
    }
    match /kandidaten/{document=**} {
      allow read, write: if true;
    }
    match /schaeden/{document=**} {
      allow read, write: if true;
    }
    match /bewohnerfotos/{document=**} {
      allow read, write: if true;
    }
    match /hausbilder/{document=**} {
      allow read, write: if true;
    }
    match /eventfotos/{document=**} {
      allow read, write: if true;
    }
    match /guests/{document=**} {
      allow read, write: if true;
    }
    match /config/{document=**} {
      allow read, write: if true;
    }
    match /anmeldungen/{document=**} {
      allow read, write: if true;
    }
    match /nachrichten/{document=**} {
      allow read, write: if true;
    }
    match /bewohnertexte/{document=**} {
      allow read, write: if true;
    }
    match /whatsapp_debug/{document=**} {
      allow read, write: if true;
    }
    match /erinnerungen/{document=**} {
      allow read, write: if true;
    }
    match /bewaesserung_tasks/{document=**} {
      allow read, write: if true;
    }
  }
}
